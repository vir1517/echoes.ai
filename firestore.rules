/**
 * Echoes Firestore Security Rules
 * 
 * Core Philosophy:
 * This ruleset implements a robust "Authorization Independence" model designed for scalability and 
 * high performance. Security is enforced through explicit user ownership for personal profiles 
 * and a denormalized "Collaborative Membership" model for shared family data.
 * 
 * Data Structure:
 * - /users/{userId}: Private user profiles, strictly accessible only by the authenticated owner.
 * - /families/{familyId}: The root of collaborative family data. Contains a 'members' map 
 *   (UID -> Role) which acts as the source of truth for access control.
 * - Sub-collections (/lovedOneProfiles, /mediaAssets, /conversations): These entities utilize 
 *   "Authorization Denormalization." A copy of the parent family's membership map ('familyMembers') 
 *   is stored directly on every child document. This allows security rules to perform local, 
 *   atomic authorization checks without expensive cross-document lookups (get() calls).
 * 
 * Key Security Decisions:
 * - Direct Ownership: User profiles are locked to the UID provided by Firebase Auth.
 * - Member-Only Access: Family-related data is only visible and modifiable by users present in 
 *    the document's membership map.
 * - Immutability of Linking Fields: Fields critical for authorization (like IDs and membership maps) 
 *   are protected from unauthorized modification after creation to prevent "privilege escalation" 
 *   or data orphaning.
 * - Prototyping Flexibility: While authorization is strict, data schemas (field types/optionality) 
 *   are flexible to support rapid iteration.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership for existing documents during update or delete. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the user is present in a document's 'familyMembers' map. */
    function isFamilyMember(data) {
      return isSignedIn() && request.auth.uid in data.familyMembers.keys();
    }

    // The 'isFamilyMemberRoot' function was unused and has been removed.
    // Its logic is handled inline where needed, or was intended for a pattern
    // not fully adopted in the current rules.

    // --- Collection Rules ---

    /**
     * @description Rules for individual User profiles.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if the user's UID matches the {userId} path.
     * @deny Any request where request.auth.uid != userId.
     * @principle Enforces a strict private user-ownership model.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for Family units. Uses a 'members' map for collaboration.
     * @path /families/{familyId}
     * @allow (get, list) if the user is a member of the family.
     * @allow (create) if the creator includes themselves in the initial 'members' map.
     * @allow (update) if the user is currently a member.
     * @allow (delete) if the user has an 'admin' role within the family.
     * @principle Shared access via a membership map within the document.
     */
    match /families/{familyId} {
      allow get, list: if isSignedIn() && (request.auth.uid in resource.data.members.keys());
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.members.keys()) && request.resource.data.id == familyId;
      allow update: if resource != null && (request.auth.uid in resource.data.members.keys()) && request.resource.data.id == resource.data.id;
      allow delete: if resource != null && (resource.data.members[request.auth.uid] == 'admin');

      /**
       * @description Loved One Profiles nested under a family.
       * @path /families/{familyId}/lovedOneProfiles/{lovedOneProfileId}
       * @allow (get, list, create, update, delete) if user is in the denormalized 'familyMembers' map.
       * @deny Access if the user's UID is missing from the 'familyMembers' field.
       * @principle Authorization Independence via denormalized membership maps.
       */
      match /lovedOneProfiles/{lovedOneProfileId} {
        allow get, list: if isFamilyMember(resource.data);
        allow create: if isFamilyMember(request.resource.data) && request.resource.data.id == lovedOneProfileId && request.resource.data.familyId == familyId;
        allow update: if resource != null && isFamilyMember(resource.data) && request.resource.data.id == resource.data.id && request.resource.data.familyId == resource.data.familyId;
        allow delete: if resource != null && isFamilyMember(resource.data);

        /**
         * @description Media Assets for a loved one.
         * @path /families/{familyId}/lovedOneProfiles/{lovedOneProfileId}/mediaAssets/{mediaAssetId}
         * @allow (get, list, create, update, delete) if user is in the 'familyMembers' map.
         * @principle Consistent authorization inherited from the family context.
         */
        match /mediaAssets/{mediaAssetId} {
          allow get, list: if isFamilyMember(resource.data);
          allow create: if isFamilyMember(request.resource.data) && request.resource.data.id == mediaAssetId && request.resource.data.lovedOneProfileId == lovedOneProfileId;
          allow update: if resource != null && isFamilyMember(resource.data) && request.resource.data.id == resource.data.id;
          allow delete: if resource != null && isFamilyMember(resource.data);
        }

        /**
         * @description Conversation transcripts and AI interactions.
         * @path /families/{familyId}/lovedOneProfiles/{lovedOneProfileId}/conversations/{conversationId}
         * @allow (get, list, create, update, delete) if user is in the 'familyMembers' map.
         * @principle Ensures private family conversations stay within the family.
         */
        match /conversations/{conversationId} {
          allow get, list: if isFamilyMember(resource.data);
          allow create: if isFamilyMember(request.resource.data) && request.resource.data.id == conversationId && request.resource.data.lovedOneProfileId == lovedOneProfileId;
          allow update: if resource != null && isFamilyMember(resource.data) && request.resource.data.id == resource.data.id;
          allow delete: if resource != null && isFamilyMember(resource.data);
        }
      }
    }
  }
}